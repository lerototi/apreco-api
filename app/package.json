{
  "name": "functions",
  "version": "1.0.0",
  "description": "",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "node lib/dev.js",
    "dev:ts": "ts-node --transpile-only -r dotenv/config src/dev.ts dotenv_config_path=.env",
    "dev:watch": "nodemon --watch src --ext ts --exec \"ts-node --transpile-only -r dotenv/config src/dev.ts dotenv_config_path=.env\"",
    "tunnel": "node lib/dev-tunnel.js",
    "tunnel:ts": "ts-node --transpile-only -r dotenv/config src/dev-tunnel.ts dotenv_config_path=.env",
    "serve": "npm run build && firebase emulators:start --only functions,firestore",
    "deploy": "npm run build && firebase deploy --only functions",
    "deploy:indexes": "firebase deploy --only firestore:indexes --project apreco-app-br",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "logs": "firebase functions:log",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "seed:marketplace": "ts-node -r dotenv/config --project tsconfig.json src/scripts/seed-marketplace.ts",
    "seed:demands": "ts-node -r dotenv/config --project tsconfig.json src/scripts/seed-demands.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.2",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
