rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Usuários ─────────────────────────────────────────────────────
    match /users/{userId} {
      // Qualquer usuário autenticado pode ler perfis (dados públicos)
      allow read: if request.auth != null;

      // Apenas o próprio usuário pode criar seu documento (uid == docId)
      allow create: if request.auth != null && request.auth.uid == userId;

      // Apenas o próprio usuário pode editar seus dados
      allow update: if request.auth != null && request.auth.uid == userId
        && !("createdAt" in request.resource.data.diff(resource.data).affectedKeys());

      // Ninguém deleta via client — apenas via Admin SDK / Cloud Functions
      allow delete: if false;
    }

    // ─── Consumer Profiles ────────────────────────────────────────────
    match /consumers/{userId} {
      // Any authenticated user can read (e.g. consumer search)
      allow read: if request.auth != null;

      // Only the owner can create/update their profile
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // Deletion only via Admin SDK
      allow delete: if false;
    }

    // ─── Perfis de Produtor Rural ──────────────────────────────────────
    match /ruralProducers/{userId} {
      // Leitura pública (marketplace de produtores)
      allow read: if request.auth != null;

      // Apenas o próprio usuário cria/edita seu perfil
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // Ninguém deleta via client
      allow delete: if false;
    }

    // ─── Establishment Profiles ───────────────────────────────────────
    match /establishments/{userId} {
      // Any authenticated user can read
      allow read: if request.auth != null;

      // Only the owner can create/update their profile
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // Deletion only via Admin SDK
      allow delete: if false;
    }

    // ─── Chat Messages ─────────────────────────────────────────────────
    // Apenas leitura — escrita é exclusiva do Admin SDK (Cloud Functions).
    // O cliente abre onSnapshot para receber mensagens em real-time sem polling.
    match /chatMessages/{messageId} {
      // Permite leitura se o usuário autenticado está em participantUids
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participantUids;

      // Nunca permite escrita via cliente — apenas Admin SDK
      allow write: if false;
    }

    // ─── Unread Counters ───────────────────────────────────────────────
    // Documento desnormalizado: {uid}:{role} → { total, uid, role, updatedAt }
    // O cliente abre onSnapshot para receber o badge em real-time.
    match /unreadCounters/{counterId} {
      // Permite leitura apenas pelo uid dono do contador
      // O docId tem formato "uid:role", e o documento tem campo uid
      allow read: if request.auth != null
        && request.auth.uid == resource.data.uid;

      // Nunca permite escrita via cliente — apenas Admin SDK
      allow write: if false;
    }

    // ─── Deliveries ────────────────────────────────────────────────────
    // Leitura e escrita apenas via Admin SDK (API).
    // O cliente consulta via REST — sem onSnapshot direto nesta coleção.
    match /deliveries/{deliveryId} {
      // Leitura permitida para produtor ou estabelecimento da entrega
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.producerUid
            || request.auth.uid == resource.data.establishmentUid);

      // Escrita apenas via Admin SDK
      allow write: if false;
    }
  }
}
